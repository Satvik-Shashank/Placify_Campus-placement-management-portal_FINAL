# =============================================================================
# Placify — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file
# =============================================================================

# ── Flask ─────────────────────────────────────────────────────────────────────
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-64-character-random-secret-key-here

# Set to 'production' when deploying, 'development' for local
FLASK_ENV=development

# ── MySQL Database ─────────────────────────────────────────────────────────────
# Option A: Individual connection vars (recommended for Railway/Aiven)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=campus_placement
MYSQL_POOL_SIZE=5

# Option B: Single DATABASE_URL (alternative, auto-parsed in production)
# DATABASE_URL=mysql://user:password@host:3306/campus_placement

# ── Also used by setup_db.py ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=campus_placement

# =============================================================================
# PRODUCTION DEPLOYMENT (Vercel + Railway MySQL)
# =============================================================================
# 1. Create a MySQL database on Railway (railway.app) — free $5 credit
# 2. Copy the connection details from Railway dashboard
# 3. Set these as environment variables in Vercel dashboard (not in .env)
#
# MYSQL_HOST     → Railway MySQL host (e.g., containers-us-west-xxx.railway.app)
# MYSQL_PORT     → Railway MySQL port (e.g., 6543)
# MYSQL_USER     → Railway MySQL user
# MYSQL_PASSWORD → Railway MySQL password
# MYSQL_DATABASE → campus_placement
# SECRET_KEY     → Run: python -c "import secrets; print(secrets.token_hex(32))"
# FLASK_ENV      → production
# =============================================================================
